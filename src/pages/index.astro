---
import Layout from "../layouts/Layout.astro";
---

<Layout title="joemclean">
  <h2 class="text-2xl font-semibold mb-5">Hi</h2>
  <p class="text-slate-700 max-w-1/3 mb-2">
    I'm Joseph McLean. I'm a third year computer science student at the
    university of Glasgow. I made this website to help you get to know me
    better. I enjoy programming, maths and music.
  </p>

  <a
    href="https://www.linkedin.com/in/joseph-mclean-8187a22b8/"
    class="text-zinc hover:text-green-300">linkedin</a
  >
  <a
    href="https://github.com/JosephMcLean118"
    class="text-zinc hover:text-green-300">github</a
  >

  <img
    src={`${import.meta.env.BASE_URL}images/joe.jpg`}
    alt="photo of myself"
    class="object-scale-down w-1/4 h-auto"
  />
</Layout>
